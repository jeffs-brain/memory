{
  "name": "@jeffs-brain/memory-react-native",
  "version": "0.1.0",
  "description": "React Native memory SDK for offline-first assistants with mobile store, hybrid search, and provider routing.",
  "license": "Apache-2.0",
  "author": "jaythegeek",
  "homepage": "https://github.com/jeffs-brain/memory#readme",
  "bugs": {
    "url": "https://github.com/jeffs-brain/memory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffs-brain/memory.git",
    "directory": "sdks/rn/memory"
  },
  "keywords": ["memory", "react-native", "expo", "sqlite", "offline-first", "llm", "hybrid-search"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "NOTICE"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "@op-engineering/op-sqlite": "*",
    "@react-native-community/netinfo": "*",
    "expo-file-system": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@op-engineering/op-sqlite": {
      "optional": true
    },
    "@react-native-community/netinfo": {
      "optional": true
    },
    "expo-file-system": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.10",
    "better-sqlite3": "^12.9.0",
    "react": "^19.1.1",
    "sqlite-vec": "^0.1.9"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  }
}
