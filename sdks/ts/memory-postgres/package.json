{
  "name": "@jeffs-brain/memory-postgres",
  "version": "0.1.0",
  "description": "Postgres and pgvector adapter for @jeffs-brain/memory: tsvector BM25, halfvec cosine, and RRF hybrid retrieval.",
  "license": "Apache-2.0",
  "author": "Alex J <alex@lleverage.ai>",
  "homepage": "https://github.com/jeffs-brain/memory#readme",
  "bugs": {
    "url": "https://github.com/jeffs-brain/memory/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeffs-brain/memory.git",
    "directory": "sdks/ts/memory-postgres"
  },
  "keywords": [
    "memory",
    "llm",
    "rag",
    "retrieval",
    "postgres",
    "pgvector",
    "bm25",
    "vector-search",
    "ai-agent"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": ["dist", "migrations", "README.md", "LICENSE", "NOTICE"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "peerDependencies": {
    "@jeffs-brain/memory": "workspace:*"
  },
  "devDependencies": {
    "@jeffs-brain/memory": "workspace:*",
    "@testcontainers/postgresql": "^11.14.0",
    "testcontainers": "^11.14.0",
    "vitest": "^2.1.8"
  }
}
